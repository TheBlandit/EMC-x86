SECTIONS {
    . = 0x1000;
    .text : { *(.text) }
    .data : { *(.data) }
    .bss : { *(.bss) }
    .eh_frame : { *(.eh_frame) }
    .got.plt : { *(.got.plt) }
    /* Place .note sections immediately after, no high addresses */
    .note : { *(.note*) }
    /* Discard unneeded sections */
    /DISCARD/ : { *(.comment .symtab .strtab .shstrtab) }
}
